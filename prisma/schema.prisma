generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  clerkId       String         @unique @map("clerk_id")
  email         String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  events        Event[]
  healthMetrics HealthMetric[]
  importJobs    ImportJob[]
  medications   Medication[]
  appointments  Appointment[]
  questions          Question[]
  homeScreenSettings HomeScreenSettings?
  homeScreenButtons  HomeScreenButton[]
  careRelationsAsUser      CareRelationship[] @relation("CareUser")
  careRelationsAsCaregiver CareRelationship[] @relation("Caregiver")

  @@map("users")
}

model Event {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  date         String
  type         String
  title        String
  description  String?
  providerName String?  @map("provider_name")
  location     String?
  tags         String[] @default([])
  isPrivate    Boolean  @default(true) @map("is_private")
  attachments  Json     @default("[]")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("events")
}

model HealthMetric {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id")
  source       String
  metricType   String   @map("metric_type")
  occurredAt   DateTime @map("occurred_at") @db.Timestamptz
  valueNumeric Float?   @map("value_numeric")
  valueText    String?  @map("value_text")
  unit         String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([source])
  @@index([metricType])
  @@index([userId, metricType, occurredAt])
  @@map("health_metrics")
}

model ImportJob {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  source        String
  status        String    @default("processing")
  importedCount Int       @default(0) @map("imported_count")
  errorMessage  String?   @map("error_message")
  finishedAt    DateTime? @map("finished_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("import_jobs")
}

model Medication {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  name         String
  dosage       String?
  frequency    String?
  startDate    String   @map("start_date")
  endDate      String?  @map("end_date")
  notes        String?
  reminderTime String?  @map("reminder_time")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
  @@map("medications")
}

model Appointment {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  title        String
  dateTime     DateTime @map("date_time") @db.Timestamptz
  providerName String?  @map("provider_name")
  location     String?
  notes        String?
  status       String   @default("scheduled")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  questions Question[]
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@map("appointments")
}

model Question {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  text          String
  source        String   @default("manual")
  appointmentId String?  @map("appointment_id")
  isAnswered    Boolean  @default(false) @map("is_answered")
  answer        String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([appointmentId])
  @@map("questions")
}

model CareRelationship {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id")
  caregiverUserId  String   @map("caregiver_user_id")
  relationshipType String   @default("anhörig") @map("relationship_type")
  status           String   @default("pending")
  canCustomizeHome Boolean  @default(true) @map("can_customize_home")
  canViewTimeline  Boolean  @default(true) @map("can_view_timeline")
  canViewMedications  Boolean @default(true) @map("can_view_medications")
  canViewAppointments Boolean @default(true) @map("can_view_appointments")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user      User @relation("CareUser", fields: [userId], references: [id], onDelete: Cascade)
  caregiver User @relation("Caregiver", fields: [caregiverUserId], references: [id], onDelete: Cascade)

  @@unique([userId, caregiverUserId])
  @@index([userId])
  @@index([caregiverUserId])
  @@map("care_relationships")
}

model HomeScreenSettings {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String   @unique @map("user_id")
  simplicityLevel       String   @default("simple") @map("simplicity_level")
  todayMessage          String?  @map("today_message")
  emergencyContactName  String?  @map("emergency_contact_name")
  emergencyContactPhone String?  @map("emergency_contact_phone")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("home_screen_settings")
}

model HomeScreenButton {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id")
  buttonKey String   @map("button_key")
  label     String
  isVisible Boolean  @default(true) @map("is_visible")
  sortOrder Int      @default(0) @map("sort_order")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, buttonKey])
  @@index([userId])
  @@map("home_screen_buttons")
}
