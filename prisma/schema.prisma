generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  clerkId       String         @unique @map("clerk_id")
  email         String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  events        Event[]
  healthMetrics HealthMetric[]
  importJobs    ImportJob[]
  medications   Medication[]
  appointments  Appointment[]
  questions     Question[]

  @@map("users")
}

model Event {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  date         String
  type         String
  title        String
  description  String?
  providerName String?  @map("provider_name")
  location     String?
  tags         String[] @default([])
  isPrivate    Boolean  @default(true) @map("is_private")
  attachments  Json     @default("[]")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("events")
}

model HealthMetric {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id")
  source       String
  metricType   String   @map("metric_type")
  occurredAt   DateTime @map("occurred_at") @db.Timestamptz
  valueNumeric Float?   @map("value_numeric")
  valueText    String?  @map("value_text")
  unit         String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([source])
  @@index([metricType])
  @@index([userId, metricType, occurredAt])
  @@map("health_metrics")
}

model ImportJob {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  source        String
  status        String    @default("processing")
  importedCount Int       @default(0) @map("imported_count")
  errorMessage  String?   @map("error_message")
  finishedAt    DateTime? @map("finished_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("import_jobs")
}

model Medication {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  name         String
  dosage       String?
  frequency    String?
  startDate    String   @map("start_date")
  endDate      String?  @map("end_date")
  notes        String?
  reminderTime String?  @map("reminder_time")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
  @@map("medications")
}

model Appointment {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  title        String
  dateTime     DateTime @map("date_time") @db.Timestamptz
  providerName String?  @map("provider_name")
  location     String?
  notes        String?
  status       String   @default("scheduled")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  questions Question[]
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@map("appointments")
}

model Question {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  text          String
  source        String   @default("manual")
  appointmentId String?  @map("appointment_id")
  isAnswered    Boolean  @default(false) @map("is_answered")
  answer        String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([appointmentId])
  @@map("questions")
}
